# 운영 PC (서버) 에서만 사용. 클라이언트로 키가 직접 노출되지만 사내망 접근에 한정됩니다.
# v1.10.70 — /api/config 엔드포인트가 이 값들을 클라이언트에 응답해 팀 기본 키로 사용.
# 사용자가 API 설정 모달에서 개인 키를 입력하면 그것이 우선 적용됩니다.

# Google AI Studio 에서 발급
GEMINI_API_KEY=

# Anthropic Console 에서 발급 (선택 — 프롬프트 자동 최적화에만 사용)
CLAUDE_API_KEY=

# 다음 변수들은 기본값으로 충분 (필요 시 override).
# PORT=3000
# HOST=0.0.0.0
# INZOI_OBJECT_LIST_URL=http://localhost:8080
